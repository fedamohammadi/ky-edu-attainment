# Data (pulled by code, never committed)
data/raw/
data/cleaned/
*.dta
*.csv
*.txt
*.dct

# Output (regenerated by code) — ignored by default
output/

# ...except finished figures and tables we want visible on GitHub
!output/figures/
!output/figures/*.png
!output/tables/
!output/tables/*.csv

# Stata junk
*.log
*.smcl

# R junk (in case you use it)
.Rhistory
.RData
.Rproj.user/

# OS junk
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code
.vscode/
